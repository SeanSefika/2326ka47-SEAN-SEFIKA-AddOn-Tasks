1. Search by Employee Name

SELECT * FROM EMPLOYEE WHERE EMPNAME = 'A';

2. Search by Partial Name Match (e.g., contains 'A')

SELECT * FROM EMPLOYEE WHERE EMPNAME LIKE '%A%';

3. Search by Job Title

SELECT * FROM EMPLOYEE WHERE EMPJOB = 'MANAGER';

4. Search by Salary Greater Than 50,000

SELECT * FROM EMPLOYEE WHERE EMPSALARY > 50000;

5. Search by Hire Date After 2010

SELECT * FROM EMPLOYEE WHERE EMP_HIREDATE > '2010-01-01';

6. Search for Employees with Salary Between 20,000 and 60,000

SELECT * FROM EMPLOYEE WHERE EMPSALARY BETWEEN 20000 AND 60000;

SORT QUERIES
1. Sort by Salary (Lowest to Highest)

SELECT * FROM EMPLOYEE ORDER BY EMPSALARY ASC;

2. Sort by Salary (Highest to Lowest)

SELECT * FROM EMPLOYEE ORDER BY EMPSALARY DESC;

3. Sort by Hire Date (Oldest First)

SELECT * FROM EMPLOYEE ORDER BY EMP_HIREDATE ASC;

4. Sort by Name Alphabetically

SELECT * FROM EMPLOYEE ORDER BY EMPNAME ASC;

5. Sort by Job Title Then Salary

SELECT * FROM EMPLOYEE ORDER BY EMPJOB ASC, EMPSALARY DESC;
